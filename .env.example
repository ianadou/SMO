# -----------------------------------------------------------------------------
# SMO — example environment variables
#
# Copy this file to .env and adjust values for your local setup.
# The .env file itself is gitignored and must NEVER be committed.
# -----------------------------------------------------------------------------

# --- Application ---

# HTTP port the SMO server listens on.
# Must be an integer in [1, 65535].
PORT=8081

# --- PostgreSQL ---

# Full connection string used by the SMO server to reach Postgres.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?OPTIONS
#
# Inside Docker Compose, the host is "postgres" (the service name).
# Outside Docker Compose (running the server directly on the host),
# the host is "localhost" and the port is whatever compose.yml exposes.
DATABASE_URL=postgres://smo:smo@postgres:5432/smo_dev?sslmode=disable

# Individual Postgres variables, used by the postgres service in compose.yml.
# These should match the user/password/database in DATABASE_URL above.
POSTGRES_USER=smo
POSTGRES_PASSWORD=smo
POSTGRES_DB=smo_dev

# --- Auth ---

# Secret used to sign organizer JWTs (HMAC-SHA256). MUST be set: the
# server refuses to boot without it.
#
# Generate a strong value with: openssl rand -base64 48
# In production this comes from a secret manager (GitHub Secrets in
# CI/CD, then Hetzner / Cloudflare env). NEVER commit a real secret.
JWT_SECRET=please-change-me-please-change-me-please-change-me

# --- Cache (optional) ---

# Redis connection URL. Three states:
#   - empty/unset       → cache disabled, repositories hit Postgres directly
#   - set + reachable   → cache enabled (cache-aside, 5min TTL by default)
#   - set + unreachable → boot fails (configuration error)
# See docs/adr/0002-cache-aside-with-redis.md for the rationale.
REDIS_URL=redis://redis:6379/0

# --- HTTP / proxies ---

# Comma-separated list of CIDRs that Gin treats as trusted upstream
# proxies. Only requests from these IPs are allowed to set
# X-Forwarded-For for c.ClientIP() resolution. Critical for the rate
# limit middleware: behind Nginx, every request would otherwise look
# like it came from the Nginx IP.
#
# Default (when unset): 127.0.0.1, ::1, and the three RFC1918 ranges
# (10/8, 172.16/12, 192.168/16) — covers compose and any deploy where
# Nginx sits in a private network.
TRUSTED_PROXIES=
