# -----------------------------------------------------------------------------
# SMO — example environment variables
#
# Copy this file to .env and adjust values for your local setup.
# The .env file itself is gitignored and must NEVER be committed.
# -----------------------------------------------------------------------------

# --- Application ---

# HTTP port the SMO server listens on.
# Must be an integer in [1, 65535].
PORT=8081

# --- PostgreSQL ---

# Full connection string used by the SMO server to reach Postgres.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?OPTIONS
#
# Inside Docker Compose, the host is "postgres" (the service name).
# Outside Docker Compose (running the server directly on the host),
# the host is "localhost" and the port is whatever compose.yml exposes.
DATABASE_URL=postgres://smo:smo@postgres:5432/smo_dev?sslmode=disable

# Individual Postgres variables, used by the postgres service in compose.yml.
# These should match the user/password/database in DATABASE_URL above.
POSTGRES_USER=smo
POSTGRES_PASSWORD=smo
POSTGRES_DB=smo_dev
