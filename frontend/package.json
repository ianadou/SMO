{
  "name": "frontend",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.6",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.9",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.2.4",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "devalue": "^5.8.1",
      "nitropack": "2.13.4",
      "ws": "^8.20.1"
